-
-```python
-MIX_CONFIG = {
-    "replay_ratio": 0.30,      # 30% 旧轮回放
-    "new_knowledge_ratio": 0.35,  # 35% 新知识
-    "anti_hallucination_ratio": 0.20,  # 20% 防幻觉
-    "identity_ratio": 0.15,    # 15% 身份强化
-}
-
-REPLAY_SOURCES = [
