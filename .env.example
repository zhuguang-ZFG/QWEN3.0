# LiMa（力码）环境变量配置
# 复制为 .env 并填入你的 API keys

# ── 管理接口认证（必须设置，否则管理面板无认证） ──
LIMA_ADMIN_TOKEN=your-admin-password-here

# ── Cloudflare 核弹级 Fallback（必须设置） ──
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_TOKEN=your-cloudflare-token

# ── 核心后端 API Keys ──
CLAUDE_API_KEY=sk-...
LONGCAT_API_KEY=ak-...
DEEPSEEK_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...
OPENROUTER_API_KEY=sk-or-...

# ── 可选后端 ──
CHINAMOBILE_API_KEY=sk-...
TOKENROUTER_API_KEY=sk-...
GROQ_API_KEY=gsk-...
CEREBRAS_API_KEY=csk-...
GOOGLE_AI_KEY=AIza...
MISTRAL_API_KEY=...
SILICONFLOW_API_KEY=sk-...
ZHIPU_API_KEY=...
BAIDU_API_KEY=bce-v3/...
TENCENT_API_KEY=ak-...
VOLCENGINE_API_KEY=ark-...
ALIYUN_API_KEY=sk-...
# 设备模型准入：DashScope 真实图生夹具（默认关；与 eval_device_model_role.py --live 配合）
# LIMA_DEVICE_ADMISSION_LIVE=1

# ── 社区/免费后端 ──
FREETHEAI_API_KEY=sta-...
ZUKI_API_KEY=zu-...
NAGA_API_KEY=ng-...
AGENTROUTER_API_KEY=sk-...
FEATHERLESS_API_KEY=rc-...

# ── LongCat 配置 ──
LONGCAT_URL=https://...
LONGCAT_MODEL=...
GPT_API_KEY=sk-...

# ── 部署 ──
LIMA_DEPLOY_PASS=

# ── 其他 ──
# Device Gateway: per-device tokens for /device/v1/ws.
# Format: device_id=token,dev_2=token2. Do not reuse provider/API keys.
LIMA_DEVICE_TOKENS=dev-1=replace-with-device-token
# Optional: memory|redis (default memory). Redis requires LIMA_DEVICE_REDIS_URL.
LIMA_DEVICE_MEMORY_STORE=
# Optional: memory|redis (default memory). Redis requires LIMA_DEVICE_REDIS_URL.
LIMA_DEVICE_LEDGER_STORE=
# Shared Redis URL when task/memory/ledger store backends use redis.
# LIMA_DEVICE_REDIS_URL=redis://127.0.0.1:6379/0

# ── Healthchecks.io dead-man (INF-B, default off) ──
LIMA_HEALTHCHECK_ENABLED=0
HEALTHCHECK_LIMA_VPS_URL=
HEALTHCHECK_LIMA_WINDOWS_URL=
HEALTHCHECK_FRPC_URL=
HEALTHCHECK_PROBE_WEEKLY_URL=
HEALTHCHECKS_API_KEY=
HEALTHCHECKS_PING_KEY=

# ── Gitee OpenAPI 搜索（雷达 P0 #3） ──
# OpenAPI search (repo + issues). Optional if git remote has oauth2@gitee.com push URL.
GITEE_TOKEN=
GITEE_SEARCH_REPO=zhuguang-cn/QWEN3.0

# ── Gitee 模力方舟 AI（GI-G-3，default off） ──
GITEE_AI_ENABLED=0
GITEE_AI_TOKEN=
GITEE_AI_BASE_URL=https://ai.gitee.com/v1

GITHUB_TOKEN=gho_...
# Telegram bot/operator support is retired. Do not add TELEGRAM_* secrets for LiMa Server.

# ── codesearch MCP (PE-B-1, default off) ──
CODESEARCH_MCP_ENABLED=0
CODESEARCH_INDEX_PATHS=D:/GIT

# ── 设备语音云 Provider（小智退役阶段 2）──
# ASR 选择：funasr | aliyun | aliyun_fallback | doubao | dashscope | whisper
# aliyun_fallback = NLS → DashScope → Whisper 自动降级
LIMA_VOICE_ASR_PROVIDER=aliyun_fallback
# TTS 选择：edge | doubao | aliyun | dashscope | mimo
LIMA_VOICE_TTS_PROVIDER=mimo

# DashScope / 百炼语音（可直接复用 ALIYUN_API_KEY；也可单独配置 DASHSCOPE_API_KEY）
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_TTS_MODEL=sambert-zhichu-v1

# 阿里云 NLS（智能语音交互）
# 兼容文档中的环境变量别名：ALIYUN_AK_ID / ALIYUN_AK_SECRET
ALIBABA_CLOUD_ACCESS_KEY_ID=your-ak-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-ak-secret
ALIYUN_AK_ID=your-ak-id
ALIYUN_AK_SECRET=your-ak-secret
ALIBABA_NLS_APP_KEY=your-nls-appkey
ALIBABA_NLS_REGION=cn-shanghai
ALIBABA_NLS_TTS_VOICE=xiaoyun

# 火山引擎 / 豆包语音
DOUBAO_ASR_APPID=your-asr-appid
DOUBAO_ASR_ACCESS_TOKEN=your-asr-token
DOUBAO_ASR_CLUSTER=volcengine_input_common
DOUBAO_TTS_APPID=your-tts-appid
DOUBAO_TTS_ACCESS_TOKEN=your-tts-token
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_VOICE=zh_female_wanwanxiaohe_moon_bigtts
DOUBAO_TTS_ENCODING=pcm

# 小米 MiMo TTS（限时免费，ASR 仅开源权重，未提供云 API）
# https://platform.xiaomimimo.com/docs/usage-guide/speech-synthesis-v2.5
MIMO_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=mimo_default
MIMO_TTS_FORMAT=wav

# ── 2D 数字人（小智退役阶段 3）──
# 默认从 esp32S_XYZ/server/xiaozhi-esp32-server/main/digital-human/ 加载
# 可覆盖为自定义目录；留空则按默认/回退路径查找
LIMA_DIGITAL_HUMAN_DIR=

# 本地 Whisper ASR（faster-whisper，VPS 内存友好）
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=

# ── SearXNG meta-search (PE-D-1, default off) ──
SEARXNG_ENABLED=0
SEARXNG_BASE_URL=http://127.0.0.1:8081
SEARXNG_CACHE_TTL=300
SEARXNG_COOLDOWN_SEC=60

# ── OpenObserve (PE-C-2, default off) ──
OPENOBSERVE_ENABLED=0
OPENOBSERVE_URL=http://127.0.0.1:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=lima_events
OPENOBSERVE_JOURNAL_STREAM=lima_journal
OPENOBSERVE_USER=root@example.com
OPENOBSERVE_PASSWORD=

