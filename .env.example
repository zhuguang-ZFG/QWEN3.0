# red V1-Flash Router Configuration
# Copy to .env and fill in your API keys

# 通用模型选择: openai / claude / qwen / deepseek
GENERAL_MODEL=qwen

# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Claude (Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Qwen (DashScope - 推荐，便宜)
DASHSCOPE_API_KEY=sk-...
QWEN_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# router_v3 / api_health_checker / closed_loop / adversarial_self_evolution / generate_dpo_data
CLAUDE_API_KEY=YOUR_KEY_HERE
GPT_API_KEY=YOUR_KEY_HERE
NVIDIA_API_KEY=YOUR_KEY_HERE
OPENROUTER_API_KEY=YOUR_KEY_HERE
