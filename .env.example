# LiMa（力码）环境变量配置
# 复制为 .env 并填入你的 API keys

# ── 管理接口认证（必须设置，否则管理面板无认证） ──
LIMA_ADMIN_TOKEN=your-admin-password-here

# ── 核心 API 认证（必须设置，否则私有/OpenAI 兼容端点拒绝访问） ──
# 主 API key；也用于 /internal/v1/* 和fleet API 等内部端点
LIMA_API_KEY=sk-lima-test-key
# 逗号分隔的备用 API keys（可选）
# LIMA_API_KEYS=sk-lima-alt-1,sk-lima-alt-2

# ── 运行时路径 ──
# SQLite 数据库路径（默认 data/lima.db）
# LIMA_DB_PATH=data/lima.db
# 统一数据目录：缓存、图谱、遥测、上传等落盘目录的根（默认 data/）
# LIMA_DATA_DIR=data

# ── CORS 配置（可选） ──
# 逗号分隔的允许来源；默认 "*"（公开接口场景，不携带 cookie）
# LIMA_CORS_ORIGINS=https://chat.donglicao.com,http://localhost:3000

# ── 品牌与身份配置（可选，留空则使用默认值） ──
# 公开模型名称（默认 LiMa / 力码）
# PUBLIC_MODEL_NAME=LiMa
# PUBLIC_MODEL_NAME_CN=力码
# 公司及出品方名称
# COMPANY_NAME_CN=深圳市动力巢科技有限公司
# COMPANY_NAME_EN=DongLiCao Technology (Shenzhen)
# COMPANY_SHORT_CN=动力巢科技
# HTTP 请求 User-Agent（默认 LiMa/2.0）
# LIMA_USER_AGENT=LiMa/2.0

# ── Cloudflare 核弹级 Fallback（必须设置） ──
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_TOKEN=your-cloudflare-token

# ── 核心后端 API Keys ──
CLAUDE_API_KEY=sk-...
LONGCAT_API_KEY=ak-...
DEEPSEEK_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...
OPENROUTER_API_KEY=sk-or-...

# ── 可选后端 ──
CHINAMOBILE_API_KEY=sk-...
TOKENROUTER_API_KEY=sk-...
GROQ_API_KEY=gsk-...
CEREBRAS_API_KEY=csk-...
GOOGLE_AI_KEY=AIza...
MISTRAL_API_KEY=...
SILICONFLOW_API_KEY=sk-...
ZHIPU_API_KEY=...
BAIDU_API_KEY=bce-v3/...
TENCENT_API_KEY=ak-...
VOLCENGINE_API_KEY=ark-...
# Agnes AI image generation fallback (OpenAI-compatible, agnes-image-2.0-flash)
AGNES_AI_API_KEY=ak-...
ALIYUN_API_KEY=sk-...
# 设备模型准入：DashScope 真实图生夹具（默认关；与 eval_device_model_role.py --live 配合）
# LIMA_DEVICE_ADMISSION_LIVE=1

# ── 社区/免费后端 ──
FREETHEAI_API_KEY=sta-...
ZUKI_API_KEY=zu-...
NAGA_API_KEY=ng-...
AGENTROUTER_API_KEY=sk-...
FEATHERLESS_API_KEY=rc-...
# LLM7 免费版每天 100 万 Tokens，15 个模型默认使用 default；不配置时以匿名模式访问
LLM7_API_KEY=

# 以下社区后端使用明文 HTTP 传输，默认禁用；设为 1 表示明确接受风险并启用
# 旧名称 FREE_AJIAKESI_ENABLED / FREE_TEAM_SPEED_ENABLED 仍兼容，但会提示弃用
# LIMA_FREE_AJIAKESI_ENABLED=0
# LIMA_FREE_TEAM_SPEED_ENABLED=0

# ── 语义路由预筛层（P4-2，默认关闭） ──
# 设为 1 启用基于 keyword/regex 的轻量语义路由预筛，命中高置信度意图时跳过 LLM 意图分析
# LIMA_SEMANTIC_ROUTER_ENABLED=0
# 短路与 LLM 意图分析的置信度阈值（默认 0.85）
# LIMA_SEMANTIC_ROUTER_THRESHOLD=0.85

# ── Instructor 结构化输出（P4-3，可选） ──
# 设为 1 启用 Instructor  patched LLM 客户端（需安装 instructor 包）
# LIMA_INSTRUCTOR_ENABLED=0

# ── Instructor 意图回退（P4-3 后续，默认关闭；需安装 instructor 包） ──
# LIMA_INSTRUCTOR_INTENT_ENABLED=0
# LIMA_INSTRUCTOR_INTENT_THRESHOLD=0.70
# LIMA_INSTRUCTOR_INTENT_PROVIDER=groq
# LIMA_INSTRUCTOR_INTENT_MODEL=llama-3.1-8b-instant
# LIMA_INSTRUCTOR_INTENT_TIMEOUT=10
# LIMA_INSTRUCTOR_INTENT_MAX_RETRIES=2
# 灰度观测期间建议同时设置 LIMA_TRACING_ENABLED=1，以便在 /admin/api/traces/recent 查看 cache_status 与 intent_source

# ── 京东云 probe 结果回流（Phase 1，默认关闭） ──
# LIMA_PROBE_INGRESS_ENABLED=0
# LIMA_PROBE_INGRESS_TOKEN=change-me-in-production

# ── 京东云 Worker 代理（Phase 2）──
# 主 VPS 调用京东云 Worker 的共享 token；Worker 上配置无 key 免费上游
# （如 POLLINATIONS_URL=https://text.pollinations.ai/openai/chat/completions）
# JDCLOUD_WORKER_TOKEN=change-me-in-production

# ── 全链路追踪（P4-8，默认开启） ──
# LIMA_TRACING_ENABLED=1

# ── 结构化日志（P4-8，默认开启） ──
# 设为 0 关闭 JSON 结构化日志，恢复 stderr 纯文本
# LIMA_STRUCTURED_LOGGING=1

# ── 滚动文件日志（AUDIT-5-O9，默认 logs/lima-router.log，单文件 100MB，保留 5 个备份） ──
# 设为空字符串可关闭文件日志（仅 stderr）
# LIMA_LOG_FILE_PATH=logs/lima-router.log
# LIMA_LOG_FILE_MAX_MB=100
# LIMA_LOG_FILE_BACKUPS=5

# ── 语义缓存层（P4-5，默认关闭） ──
# 设为 1 启用 embedding 相似度缓存；未配置 JINA_API_KEY 时自动使用离线 fake embedder
# LIMA_SEMANTIC_CACHE_ENABLED=0
# LIMA_SEMANTIC_CACHE_THRESHOLD=0.92
# LIMA_SEMANTIC_CACHE_TTL=3600
# LIMA_SEMANTIC_CACHE_DB=data/semantic_cache.db
# LIMA_SEMANTIC_CACHE_DIMENSIONS=256
# LIMA_EMBEDDING_CACHE_SIZE=1024
# 灰度观测期间建议同时设置 LIMA_TRACING_ENABLED=1，并通过 /admin/api/metrics/gray 观察命中率

# ── LongCat 配置 ──
LONGCAT_URL=https://...
LONGCAT_MODEL=...
GPT_API_KEY=sk-...

# ── 部署 ──
LIMA_DEPLOY_PASS=
# Optional: SSH deploy key path and known_hosts for CI / local deploy scripts.
# LIMA_DEPLOY_KEY_PATH=~/.ssh/id_ed25519
# LIMA_DEPLOY_KNOWN_HOSTS=~/.ssh/known_hosts

# JDCloud 监控节点部署（P3-18）
# JDCLOUD_HOST=117.72.118.95
# JDCLOUD_USER=root
# JDCLOUD_ROOT_PASSWORD=

# 运行时环境：设为 production 会启用更严格的就绪检查（如 /device/v1/health 503 门控）
# LIMA_RUNTIME_ENV=production
# 是否允许公开端点匿名访问（生产环境同样生效，取决于 LIMA_ALLOW_ANONYMOUS）
# LIMA_ALLOW_ANONYMOUS=1
# Device Gateway: per-device tokens for /device/v1/ws.
# Format: device_id=token,dev_2=token2. Do not reuse provider/API keys.
LIMA_DEVICE_TOKENS=dev-1=replace-with-device-token
# 空 token 设备是否允许已注册设备（v2_device 表存在）接入 /device/v1/ws。
# 安全默认 0（关闭）。仅当固件确实无法写入 token（如当前 U8）且设备 ID 不可猜测时才可设 1。
# LIMA_WS_REGISTERED_DEVICE_FALLBACK=0
# Optional: memory|redis (default memory). Redis requires LIMA_DEVICE_REDIS_URL.
LIMA_DEVICE_MEMORY_STORE=
# Optional: memory|redis (default memory). Redis requires LIMA_DEVICE_REDIS_URL.
LIMA_DEVICE_LEDGER_STORE=
# Optional: memory|redis (default memory). Redis requires LIMA_DEVICE_REDIS_URL.
LIMA_DEVICE_TASK_STORE=
# Shared Redis URL when task/memory/ledger store backends use redis.
# LIMA_DEVICE_REDIS_URL=redis://127.0.0.1:6379/0
# Redis key TTLs for task/memory/ledger backends (seconds, default 30/90/90 days)
# LIMA_REDIS_TASK_TTL=2592000
# LIMA_REDIS_MEMORY_INDEX_TTL=2592000
# LIMA_REDIS_LEDGER_TTL=7776000

# 设备 App JWT 鉴权（必须设置，否则 device app 登录不可用）
LIMA_JWT_SECRET=change-me-minimum-32-bytes-long-secret

# 设备 App / 小智兼容层：开发模式下允许使用静态短信登录码（1/true/yes/on）
# 未启用时，即使配置了 LIMA_XIAOZHI_LOGIN_CODE，静态码登录接口也会返回 503
# LIMA_XIAOZHI_DEV_STATIC_LOGIN_CODE=1
# 设备 App 鉴权速率限制（每 IP 每分钟，滑动窗口）
# LIMA_DEVICE_AUTH_REGISTER_PER_MIN=5
# LIMA_DEVICE_AUTH_LOGIN_PER_MIN=20
# LIMA_DEVICE_AUTH_SMS_PER_MIN=10
# 跨 worker 一致限流：auto=有 LIMA_DEVICE_REDIS_URL 时用 Redis；1=强制 Redis；0=仅进程内内存
# LIMA_DEVICE_AUTH_RATE_REDIS=auto
# LIMA_DEVICE_AUTH_RATE_REDIS_URL=redis://127.0.0.1:6379/0

# 其他关键路由速率限制（每 IP/账户 每分钟，滑动窗口）
# LIMA_ADMIN_LOGIN_PER_MIN=10
# LIMA_OUTCOME_INGEST_PER_MIN=60
# LIMA_UPLOAD_PER_MIN=30
# 全局关闭所有路由级速率限制（仅测试/调试使用）
# LIMA_RATE_LIMIT_DISABLE=0

# 上传文件下载：默认需 token 或 Authorization；设为 1 时 GET /uploads/* 公开（不推荐生产）
# LIMA_UPLOAD_PUBLIC_GET=0
# 上传 token 签名密钥（默认回退到 LIMA_JWT_SECRET）
# LIMA_UPLOAD_TOKEN_SECRET=
# LIMA_UPLOAD_TOKEN_TTL=86400

# ── 公开演示 /public/demo/chat ──
# 设为 1 启用无需 API key 的公开演示端点（生产环境慎用）
# LIMA_PUBLIC_DEMO_ENABLED=0
# 公开演示每 IP 每分钟最大请求数
# LIMA_PUBLIC_DEMO_MAX_PER_MINUTE=10

# ── Healthchecks.io dead-man (INF-B, default off) ──
LIMA_HEALTHCHECK_ENABLED=0
HEALTHCHECK_LIMA_VPS_URL=
HEALTHCHECK_LIMA_WINDOWS_URL=
HEALTHCHECK_FRPC_URL=
HEALTHCHECK_PROBE_WEEKLY_URL=
HEALTHCHECKS_API_KEY=
HEALTHCHECKS_PING_KEY=

# ── Gitee OpenAPI 搜索（雷达 P0 #3） ──
# OpenAPI search (repo + issues). Gitee 镜像同步脚本已退役并归档至 docs/archive/retired/，
# 此处 token 仅用于 Gitee OpenAPI 搜索（如 provider 雷达）。
GITEE_TOKEN=
# Fallback alias used by Gitee OpenAPI adapters when GITEE_TOKEN is unset/empty.
GITEE_ACCESS_TOKEN=
GITEE_SEARCH_REPO=zhuguang-cn/QWEN3.0

# ── Gitee 模力方舟 AI（GI-G-3，default off） ──
GITEE_AI_ENABLED=0
GITEE_AI_TOKEN=
GITEE_AI_BASE_URL=https://ai.gitee.com/v1

GITHUB_TOKEN=gho_...
# Telegram bot/operator support is retired. Do not add TELEGRAM_* secrets for LiMa Server.

# ── codesearch MCP (PE-B-1, default off) ──
CODESEARCH_MCP_ENABLED=0
CODESEARCH_INDEX_PATHS=D:/GIT

# ── 设备语音云 Provider（小智退役阶段 2）──
# 总开关：设为 1 才启用设备网关的 VAD/ASR/LLM/TTS 语音管线（数字人语音交互必需）
LIMA_VOICE_ENABLED=0
# ASR 选择：funasr | aliyun | aliyun_fallback | doubao | dashscope | whisper
# aliyun_fallback = NLS → DashScope → Whisper 自动降级
LIMA_VOICE_ASR_PROVIDER=aliyun_fallback
# TTS 选择：edge | doubao | aliyun | dashscope | mimo
LIMA_VOICE_TTS_PROVIDER=mimo

# DashScope / 百炼语音（可直接复用 ALIYUN_API_KEY；也可单独配置 DASHSCOPE_API_KEY）
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=fun-asr-realtime
DASHSCOPE_TTS_MODEL=sambert-zhichu-v1

# 阿里云 NLS（智能语音交互）
# 兼容文档中的环境变量别名：ALIYUN_AK_ID / ALIYUN_AK_SECRET
ALIBABA_CLOUD_ACCESS_KEY_ID=your-ak-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-ak-secret
ALIYUN_AK_ID=your-ak-id
ALIYUN_AK_SECRET=your-ak-secret
ALIBABA_NLS_APP_KEY=your-nls-appkey
ALIBABA_NLS_REGION=cn-shanghai
ALIBABA_NLS_TTS_VOICE=xiaoyun

# 火山引擎 / 豆包语音
DOUBAO_ASR_APPID=your-asr-appid
DOUBAO_ASR_ACCESS_TOKEN=your-asr-token
DOUBAO_ASR_CLUSTER=volcengine_input_common
DOUBAO_TTS_APPID=your-tts-appid
DOUBAO_TTS_ACCESS_TOKEN=your-tts-token
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_VOICE=zh_female_wanwanxiaohe_moon_bigtts
DOUBAO_TTS_ENCODING=pcm

# 小米 MiMo TTS（限时免费，ASR 仅开源权重，未提供云 API）
# https://platform.xiaomimimo.com/docs/usage-guide/speech-synthesis-v2.5
# device_voice/providers/tts_mimo.py 使用 MIMO_API_KEY
MIMO_API_KEY=
# backends_registry 中 mimo-tts / mimo-v2-pro 后端分别使用以下 key
MIMO_TTS_KEY=
MIMO_V2_PRO_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=mimo_default
MIMO_TTS_FORMAT=wav

# ai.xmiaom.com OpenAI 兼容后端（gpt-image-2）
XMIAOM_API_KEY=
# xmiaom 图像生成单后端超时（秒），默认 30；过长会拖慢 Pollinations 回退
LIMA_XMIAOM_IMAGE_TIMEOUT_SECONDS=30
# 图像生成结果缓存（秒），0 表示关闭；默认 3600
LIMA_IMAGE_CACHE_TTL_SECONDS=3600
# 图像生成结果缓存最大条目数，默认 100
LIMA_IMAGE_CACHE_MAX_ENTRIES=100
# OpenAI 兼容图像后端（FreeTheAi 等）调用超时（秒），默认 120
LIMA_OPENAI_IMAGE_TIMEOUT_SECONDS=120
# 中文 prompt 自动翻译成英文（ Pollinations 后端；使用 Pollinations 免费文本接口），默认开启
LIMA_IMAGE_PROMPT_TRANSLATE_ZH=1
# 中文 prompt 翻译接口超时（秒），默认 5
LIMA_IMAGE_PROMPT_TRANSLATE_TIMEOUT_SECONDS=5

# ── 2D 数字人（小智退役阶段 3）──
# 默认从 esp32S_XYZ/server/xiaozhi-esp32-server/main/digital-human/ 加载
# 可覆盖为自定义目录；留空则按默认/回退路径查找
LIMA_DIGITAL_HUMAN_DIR=
# 数字人页面首次打开时的默认连接参数（仅当用户未填写时生效）
LIMA_DIGITAL_HUMAN_DEFAULT_DEVICE_ID=web-tester
LIMA_DIGITAL_HUMAN_DEFAULT_DEVICE_NAME=Web 数字人
LIMA_DIGITAL_HUMAN_DEFAULT_CLIENT_ID=web_test_client
# 留空则用户需手动填写；生产环境请通过 per-device token 控制
LIMA_DIGITAL_HUMAN_DEFAULT_TOKEN=
LIMA_DIGITAL_HUMAN_DEFAULT_WAKEUP_WORD_ENABLED=false

# 本地 Whisper ASR（faster-whisper，VPS 内存友好）
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=

# ── SearXNG meta-search (PE-D-1, default off) ──
SEARXNG_ENABLED=0
# SEARXNG_URL takes precedence over SEARXNG_BASE_URL in code; set one of them.
# SEARXNG_URL=http://127.0.0.1:8081
SEARXNG_BASE_URL=http://127.0.0.1:8081
SEARXNG_CACHE_TTL=300
SEARXNG_COOLDOWN_SEC=60

# ── OpenObserve (PE-C-2, default off) ──
OPENOBSERVE_ENABLED=0
OPENOBSERVE_URL=http://127.0.0.1:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=lima_events
OPENOBSERVE_JOURNAL_STREAM=lima_journal
OPENOBSERVE_USER=root@example.com
OPENOBSERVE_PASSWORD=

# ── 小程序通知、登录与设备发现 ──
# 微信小程序 appid / secret，同时用于：
#   - 订阅消息通知（device_logic/notifications.py）
#   - manager-mobile 一键登录（jscode2session）
# 不配置时通知功能优雅失败，登录返回 503（除非 LIMA_XIAOZHI_WECHAT_DEV_LOGIN=1）
LIMA_WX_APPID=
LIMA_WX_SECRET=
# 微信小程序登录：1=使用 dev mock（code 直接当 openid），0=真实 jscode2session
LIMA_XIAOZHI_WECHAT_DEV_LOGIN=0
# 设备 WebSocket 接入地址（配网/发现时下发给设备），不配置则回退到公网域名
LIMA_DEVICE_WS_URL=wss://chat.donglicao.com/device/v1/ws
# 是否允许设备 WebSocket 通过 ?token= / ?authorization= query 参数传 Bearer token（AUDIT-11-W2）。
# 默认 0（拒绝，推荐用 POST /device/v1/ws/ticket 换一次性 ticket 或 Authorization header）。
# 仅用于 legacy 客户端迁移期临时回退。
LIMA_DEVICE_WS_ALLOW_QUERY_TOKEN=0

# ── 京东云 Alertmanager 通知渠道 ──
# 用于 deploy/jdcloud/update_alertmanager.sh 替换 alertmanager.yml 中的 webhook 占位符。
# 至少配置一个真实渠道，否则告警只会打到占位 URL（通知不会真正送达）。
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx


# === Litestream 异地备份（AUDIT-7-D3）===
# 配置后 litestream 会把关键 SQLite 库（sessions/agent_tasks/tool_audit/outcome_ledger）
# 实时复制到 S3 兼容对象存储（推荐 Cloudflare R2，零出口流量费）。
# 不配置则仅本地 file replica（VPS 整机故障时主库+本地副本同时丢失）。
# LITESTREAM_S3_BUCKET=
# LITESTREAM_S3_REGION=apac
# LITESTREAM_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=
