# LiMa（力码）环境变量配置
# 复制为 .env 并填入你的 API keys

# ── 管理接口认证（必须设置，否则管理面板无认证） ──
LIMA_ADMIN_TOKEN=your-admin-password-here

# ── Cloudflare 核弹级 Fallback（必须设置） ──
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_TOKEN=your-cloudflare-token

# ── 核心后端 API Keys ──
CLAUDE_API_KEY=sk-...
LONGCAT_API_KEY=ak-...
DEEPSEEK_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...
FREEMODEL_API_KEY=fe_oa_...
OPENROUTER_API_KEY=sk-or-...

# ── 可选后端 ──
CHINAMOBILE_API_KEY=sk-...
GROQ_API_KEY=gsk-...
CEREBRAS_API_KEY=csk-...
GOOGLE_AI_KEY=AIza...
MISTRAL_API_KEY=...
SILICONFLOW_API_KEY=sk-...
ZHIPU_API_KEY=...
BAIDU_API_KEY=bce-v3/...
TENCENT_API_KEY=ak-...
VOLCENGINE_API_KEY=ark-...
ALIYUN_API_KEY=sk-...
MODELSCOPE_API_KEY=ms-...

# ── 社区/免费后端 ──
FREE_OPENAI_NEXT_KEY=sk-...
FREE_CENTOS_KEY=sk-...
FREE_MUYUAN_KEY=sk-...
FREE_AJIAKESI_KEY=sk-...
FREETHEAI_API_KEY=sta-...
ZUKI_API_KEY=zu-...
NAGA_API_KEY=ng-...
AGENTROUTER_API_KEY=sk-...
FEATHERLESS_API_KEY=rc-...
OPENGATEWAY_API_KEY=ogw_live_...
AGNES_AI_API_KEY=sk-...

# ── LongCat 配置 ──
LONGCAT_URL=https://...
LONGCAT_MODEL=...
GPT_API_KEY=sk-...

# ── 部署 ──
LIMA_DEPLOY_PASS=

# ── 其他 ──
# Device Gateway: per-device tokens for /device/v1/ws.
# Format: device_id=token,dev_2=token2. Do not reuse provider/API keys.
LIMA_DEVICE_TOKENS=dev-1=replace-with-device-token

# ── Healthchecks.io dead-man (INF-B, default off) ──
LIMA_HEALTHCHECK_ENABLED=0
HEALTHCHECK_LIMA_VPS_URL=
HEALTHCHECK_LIMA_WINDOWS_URL=
HEALTHCHECK_FRPC_URL=
HEALTHCHECK_PROBE_WEEKLY_URL=
HEALTHCHECKS_API_KEY=
HEALTHCHECKS_PING_KEY=

# ── Gitee WebHook (GI-G-2, default off) ──
GITEE_WEBHOOK_ENABLED=0
GITEE_WEBHOOK_SECRET=
GITEE_WEBHOOK_REPOS=zhuguang-cn/QWEN3.0
GITEE_WEBHOOK_DEDUPE_GITHUB=1

# ── Gitee OpenAPI 搜索（雷达 P0 #3） ──
# OpenAPI search (repo + issues). Optional if git remote has oauth2@gitee.com push URL.
GITEE_TOKEN=
GITEE_SEARCH_REPO=zhuguang-cn/QWEN3.0

# ── Gitee 模力方舟 AI（GI-G-3，default off） ──
GITEE_AI_ENABLED=0
GITEE_AI_TOKEN=
GITEE_AI_BASE_URL=https://ai.gitee.com/v1

# ── GitHub WebHook（CQ-GH-001 / TG-GH-5，default off on local） ──
GITHUB_WEBHOOK_ENABLED=0
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_REPOS=owner/repo
GITHUB_WEBHOOK_AUTO_TASK=0

GITHUB_TOKEN=gho_...
# ── Telegram push translation (TG-GH-7) ──
TELEGRAM_PUSH_TRANSLATE=0
TELEGRAM_PUSH_TRANSLATE_ENGINE=llm
TELEGRAM_PUSH_TRANSLATE_BACKEND=scnet_qwen30b,cf_llama70b

# ── codesearch MCP (PE-B-1, default off) ──
CODESEARCH_MCP_ENABLED=0
CODESEARCH_INDEX_PATHS=D:/GIT,D:/GIT/deepcode-cli

# ── SearXNG meta-search (PE-D-1, default off) ──
SEARXNG_ENABLED=0
SEARXNG_BASE_URL=http://127.0.0.1:8081
SEARXNG_CACHE_TTL=300
SEARXNG_COOLDOWN_SEC=60

# ── OpenCode IDE Optimization ──
# Tool call mode: "direct" (default, OpenAI native) or "convert" (legacy Anthropic pipeline)
LIMA_OPENCODE_TOOL_MODE=direct
# Backend affinity boost for fast coding backends (1.0 = disabled)
LIMA_OPENCODE_FAST_BOOST=1.15
# Rate limit multiplier for IDE clients
LIMA_OPENCODE_RATE_MULTIPLIER=5
# Preferred backend for OpenCode (flash = lower latency; pro = higher quality)
LIMA_OPENCODE_PREFERRED_BACKEND=scnet_ds_flash
# Pin OpenCode to preferred backend; skip speculative routing (1=on, 0=off)
LIMA_OPENCODE_DIRECT_STREAM=1
# Number of recent turns to preserve during context compression
LIMA_OPENCODE_KEEP_RECENT_TURNS=8
# Skip speculative execution for tool calls (1=skip, 0=allow)
LIMA_OPENCODE_SKIP_SPECULATIVE_TOOLS=1
# Return curated model list for OpenCode (1=enabled, 0=disabled)
LIMA_OPENCODE_MODEL_LIST=1

# ── OpenObserve (PE-C-2, default off) ──
OPENOBSERVE_ENABLED=0
OPENOBSERVE_URL=http://127.0.0.1:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=lima_events
OPENOBSERVE_JOURNAL_STREAM=lima_journal
OPENOBSERVE_USER=root@example.com
OPENOBSERVE_PASSWORD=

