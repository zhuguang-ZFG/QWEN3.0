        {"type": "L", "x": 50, "y": 100},
        {"type": "L", "x": 100, "y": 0},
        {"type": "L", "x": 50, "y": 50},
        {"type": "Z"}
      ],
      "expected_points": 5,
      "note": "复杂多边形光栅"
