  "cases": [
    {
      "id": 1,
      "input": {
        "data": "���rectangle 100x50 at (0,0)",
        "format": "png"
      },
      "expected": [
        {"type": "M", "x": 0, "y": 0},
        {"type": "L", "x": 100, "y": 0},
        {"type": "L", "x": 100, "y": 50},
